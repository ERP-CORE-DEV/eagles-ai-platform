/* {{NAME}} — token-only styles */

.{{KEBAB}} {
  display: block;
  background-color: var(--system-background-surface);
  color: var(--system-text-primary);
  border: 1px solid var(--system-border-default);
  border-radius: var(--radius-md);
  padding: var(--spacing-4);
  font-family: var(--typography-family-base);
  font-size: var(--typography-size-base);
  line-height: var(--typography-line-height-normal);
  transition: var(--transition-fast);
}

.{{KEBAB}}:focus-within {
  border-color: var(--system-border-focus);
  box-shadow: var(--component-input-shadow-focus);
}
