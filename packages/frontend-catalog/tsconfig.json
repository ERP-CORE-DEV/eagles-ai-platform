{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["tokens/**/*.ts", "stories/**/*.ts", "stories/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
