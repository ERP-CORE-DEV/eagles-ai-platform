{
  "name": "@eagles-ai-platform/frontend-catalog",
  "version": "0.1.0",
  "private": true,
  "description": "Design token pipeline + Storybook catalog for RH-OptimERP frontend components",
  "type": "module",
  "scripts": {
    "build:tokens": "style-dictionary build --config tokens/style-dictionary.config.ts",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o dist/storybook",
    "build": "pnpm build:tokens && pnpm build:storybook",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "antd": "^5.29.3",
    "react": "^18.3.1",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "style-dictionary": "^4.4.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "peerDependencies": {
    "antd": "^5.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
